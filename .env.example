# Copy this file to `.env` and fill in your key, then run: pnpm generate:trail
# `.env` is git-ignored, so your key stays local and is never committed.

# OpenAI API key used by scripts/generate-trail-scenes.mjs to paint the Home
# page trail scenes (public/trail/scene-0N.png).
OPENAI_API_KEY=

# Optional overrides:
# TRAIL_MODEL=gpt-image-1
# TRAIL_SIZE=1536x1024
# TRAIL_SCENES=1,2,3,4,5
