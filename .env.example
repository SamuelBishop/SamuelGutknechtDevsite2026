# Copy this file to `.env` and fill in your key, then run: pnpm generate:trail
# `.env` is git-ignored, so your key stays local and is never committed.

# OpenAI API key used by scripts/generate-trail-scenes.mjs to paint the Home
# page trail scenes (public/trail/scene-0N.png).
OPENAI_API_KEY=

# Generic image asset generation used by `/generate-asset`.
# IMAGE_MODEL=gpt-image-2
# IMAGE_SIZE=1024x1024
# IMAGE_QUALITY=high
# IMAGE_BACKGROUND=auto

# Optional overrides:
# TRAIL_MODEL=gpt-image-1
# TRAIL_SIZE=1536x1024
# TRAIL_SCENES=1,2,3,4,5

# Web3Forms access key for the contact form (https://web3forms.com).
# Create a free key tied to your email, then paste it here. Exposed to the
# browser, so only use a Web3Forms key (never a secret API key).
VITE_WEB3FORMS_ACCESS_KEY=

# Substack publication for the "Written Works" section. Used by
# scripts/generate-posts.mjs (pnpm generate:posts) to build
# src/content/posts.generated.json. Accepts the publication base URL or the full
# /feed URL. Defaults to https://samgutknecht.substack.com when unset.
# SUBSTACK_URL=https://samgutknecht.substack.com

# GitHub profile for the Home "consistency" contribution heatmap. Used by
# scripts/generate-github-activity.mjs (pnpm generate:github). Credential-free —
# reads the public contributions calendar. Defaults to SamuelBishop when unset.
# GITHUB_USERNAME=SamuelBishop

# Strava API credentials for the Home "consistency" activity heatmap. Used by
# scripts/generate-strava-activity.mjs (pnpm generate:strava). One-time setup:
#   1. Create a free app at https://www.strava.com/settings/api
#      (Authorization Callback Domain = localhost).
#   2. Paste the Client ID / Secret below, then run `pnpm strava:auth` and follow
#      the prompts to mint STRAVA_REFRESH_TOKEN.
# In production, set these three as Vercel environment variables so each deploy
# refreshes the graph. If unset, the build keeps the last-committed snapshot.
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REFRESH_TOKEN=
