{
  "name": "samuel-gutknecht-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "generate:asset": "node scripts/generate-asset.mjs",
    "generate:trail": "node scripts/generate-trail-scenes.mjs",
    "generate:objects": "node scripts/generate-objects.mjs",
    "generate:posts": "node scripts/generate-posts.mjs",
    "generate:github": "node scripts/generate-github-activity.mjs",
    "generate:strava": "node scripts/generate-strava-activity.mjs",
    "generate:activity": "node scripts/generate-github-activity.mjs && node scripts/generate-strava-activity.mjs",
    "strava:auth": "node scripts/strava-auth.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-xml-parser": "^5.9.3",
    "globals": "^16.5.0",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sanitize-html": "^2.17.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@11.7.0"
}
